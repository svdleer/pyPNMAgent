{
    "agent_id": "jump-server-01",
    "pypnm_server": {
        "url": "ws://127.0.0.1:8000/api/agents/ws",
        "auth_token": "your-secure-token-here"
    },
    "peer_tunnels": [
        {
            "_comment": "Reverse SSH tunnel to CM agent host: opens remote_port on ssh_host so the CM agent can reach PyPNM via localhost:remote_port there",
            "label": "cm-agent",
            "enabled": false,
            "ssh_host": "cm-agent-host.internal",
            "ssh_port": 22,
            "ssh_user": "svdleer",
            "key_file": "~/.ssh/id_ed25519",
            "ssh_options": [
                "PreferredAuthentications=publickey",
                "PubkeyAuthentication=yes",
                "IdentitiesOnly=yes"
            ],
            "local_port": 8000,
            "remote_port": 8000
        },
        {
            "_comment": "Reverse SSH tunnel to get-file agent host: opens remote_port so the file agent can reach PyPNM via localhost:remote_port there",
            "label": "file-agent",
            "enabled": false,
            "ssh_host": "file-agent-host.internal",
            "ssh_port": 22,
            "ssh_user": "svdleer",
            "key_file": "~/.ssh/id_ed25519",
            "ssh_options": [
                "PreferredAuthentications=publickey",
                "PubkeyAuthentication=yes",
                "IdentitiesOnly=yes"
            ],
            "local_port": 8000,
            "remote_port": 8001
        }
    ],
    "cmts_access": {
        "enabled": true,
        "community": "public",
        "write_community": "private",
        "ssh_enabled": false,
        "ssh_user": "admin",
        "ssh_key_file": "~/.ssh/id_ed25519"
    },
    "cm_access": {
        "enabled": true,
        "community": "your-cm-community",
        "proxy": {
            "host": "cm-proxy.internal",
            "user": "pnm-agent",
            "key_file": "~/.ssh/id_ed25519"
        }
    },
    "tftp_server": {
        "tftp_path": "/tftpboot"
    }
}
