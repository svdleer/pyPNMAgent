# PyPNM Agent - autossh tunnel configuration
# Copy to .env and fill in your values, then run_background.sh start
#
# Topology:
#   [Agent server]  -->  autossh forward  -->  [PyPNM server:8000]
#   localhost:42001 (agent connects here)
#
#   [PyPNM server]  <--  autossh reverse  <--  [Agent server modems]
#   server:4444  (optional, for modem SNMP reach-back)

AUTOSSH_ENABLED=true

# SSH host = the server running PyPNM API
AUTOSSH_SSH_HOST=pypnm-server.example.com
AUTOSSH_SSH_PORT=22
AUTOSSH_SSH_USER=svdleer
AUTOSSH_SSH_KEY=~/.ssh/id_ed25519

# Forward tunnel: localhost:42001 -> pypnm-server:8000
AUTOSSH_LOCAL_PORT=42001
AUTOSSH_REMOTE_PORT=8000

# Reverse tunnel (leave blank to disable)
# Allows PyPNM to reach modems through this agent as TCP relay
AUTOSSH_REVERSE_LOCAL_PORT=
AUTOSSH_REVERSE_REMOTE_PORT=

# agent_config.json: set pypnm_server.url = ws://localhost:42001/api/agents/ws
